{
  "expo": {
    "name": "Spey Ride",
    "slug": "spey-ride",
    "version": "1.0.0",
    "orientation": "portrait",
    "scheme": "speyride",
    "userInterfaceStyle": "automatic",
    "splash": {
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "assetBundlePatterns": ["**/*"],
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "taxi.speyride",
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Spey Ride uses your location to find nearby drivers and provide pickups.",
        "NSLocationAlwaysAndWhenInUseUsageDescription": "Drivers share location while online so riders can be matched and tracked. Background location keeps the ride live when the screen is locked.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["location", "fetch"]
      }
    },
    "android": {
      "package": "taxi.speyride",
      "permissions": [
        "ACCESS_FINE_LOCATION",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_BACKGROUND_LOCATION",
        "FOREGROUND_SERVICE",
        "FOREGROUND_SERVICE_LOCATION"
      ]
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-secure-store",
      "expo-web-browser",
      [
        "expo-location",
        {
          "locationAlwaysAndWhenInUsePermission": "Allow Spey Ride to use your location even while in the background so riders can track your arrival.",
          "isIosBackgroundLocationEnabled": true,
          "isAndroidBackgroundLocationEnabled": true
        }
      ]
    ],
    "experiments": {
      "typedRoutes": false
    },
    "extra": {
      "router": {
        "origin": false
      }
    }
  }
}
