# ─── Database ─────────────────────────────────────────────────────────────────
# Option 1: Local MongoDB (run: mongod --dbpath /tmp/speyride-db)
# MONGO_URL=mongodb://localhost:27017
# Option 2: MongoDB Atlas free tier — replace with your connection string
MONGO_URL=mongodb://localhost:27017
DB_NAME=speyride

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_SECRET=speyride-super-secret-jwt-key-change-in-production-2026
JWT_ALGORITHM=HS256

# ─── Twilio OTP ───────────────────────────────────────────────────────────────
# Leave blank → app uses DEV MODE (code shown on screen, no SMS sent)
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_VERIFY_SERVICE_SID=

# ─── Stripe ───────────────────────────────────────────────────────────────────
# Leave blank → Stripe features disabled gracefully (cash/dev payments still work)
# Get test keys at: https://dashboard.stripe.com/test/apikeys
STRIPE_API_KEY=
STRIPE_WEBHOOK_SECRET=

# ─── CORS ─────────────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
